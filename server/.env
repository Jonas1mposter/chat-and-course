# 复制为 .env 并修改
PORT=4000
DATABASE_URL=postgres://xueshe:CHANGE_ME@127.0.0.1:5432/xueshe
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# 允许跨域的前端域名（多个用逗号分隔），开发可填 *
CORS_ORIGIN=*

# 腾讯云 COS（视频上传）— 在腾讯云控制台 → 访问管理 CAM 创建子用户 + 给 COS 桶授权
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=        # 例如：superbrain-1300000000
COS_REGION=        # 例如：ap-nanjing
# 可选：自定义 CDN 域名（不带末尾斜杠），不填则用默认 cos 域名
COS_CDN_BASE=